    "offering": {
      "app": "emran/screen-agent",
      "version": "1.0.0",
      "mode": "single-shot",
      "capacity": 1,
      "price": {
        "price_per_unit": 2719,
        "pixels_per_unit": 1,
        "unit": "WEI",
